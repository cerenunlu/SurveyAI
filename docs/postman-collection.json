                  "",
                  "const body = pm.response.json();",
                  "pm.test('Contacts list is an array', function () {",
                  "  pm.expect(Array.isArray(body)).to.eql(true);",
                  "});",
                  "",
                  "console.log('List Operation Contacts response body:', body);",
                  "postman.setNextRequest(null);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
