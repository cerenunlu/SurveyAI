                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contacts\": [\n    {\n      \"name\": \"Alice Example\",\n      \"phoneNumber\": \"+15550000001\"\n    },\n    {\n      \"name\": \"Bob Example\",\n      \"phoneNumber\": \"+15550000002\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/operations/{{operationId}}/contacts?companyId={{companyId}}",
              "host": [
