              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('At least two contacts uploaded', function () {",
                  "  pm.expect(body.length).to.be.at.least(2);",
                  "});",
                  "",
                  "console.log('Upload Operation Contacts response body:', body);",
                  "postman.setNextRequest('List Operation Contacts');"
                ]
              }
            }
          ],
